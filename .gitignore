cat > .gitignore << 'EOF'
# Dependências
node_modules/

# Relatórios e resultados
reports/
test-results/
playwright-report/
cucumber-report.*
k6-*.html
k6-*.json

# IDE / editor
.idea/
*.iml
.vscode/

# Sistema operacional
.DS_Store
Thumbs.db

# Temporários / logs
*.log
*.tmp

jsconfig.json
tsconfig.json